{
  "name": "Metaphor editor (tei)",
  "extension": "xml",
  "js": "token.js,token-metaphor.js",
  "css": "token.css",
  "template": "template-metaphor.xml",
  "chunks": {
    "<teiHeader>.*?(?:</teiHeader>)": ".mm_header",
    "<head(?:| [^>]*)>.*?(?:</head>)": ".mm_head",
    "<div(?:| [^>]*)>.*?(?:</div>)": "mm_p"
  }
}
